# Copy this file to .env and fill in real values. NEVER commit .env.
# `python scripts/verify_environment.py` validates every value below.

# --- Splunk Enterprise (management port + auth token) --------------------------
# Create the token: Settings → Tokens → New Token. Scope to a service account
# whose role is restricted to index=counterspell only.
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_TOKEN=replace-with-splunkd-auth-token

# --- HEC (HTTP Event Collector) for synthetic data + red-team injects ---------
# Create the token: Settings → Data inputs → HTTP Event Collector → New Token
# (name: counterspell_hec, allowed indexes: counterspell, default index: counterspell)
SPLUNK_HEC_URL=https://localhost:8088/services/collector/event
SPLUNK_HEC_TOKEN=replace-with-hec-token

# --- Splunk MCP Server (optional but earns judging credit) --------------------
# Install "Splunk MCP Server" from Splunkbase (app 7931, v1.1+). The server
# speaks JSON-RPC 2.0 over streamable HTTP at /services/mcp on the mgmt port.
# Copy the exact endpoint + encrypted token from the MCP Server app's UI.
#   MCP_URL=https://localhost:8089/services/mcp
# Leave MCP_URL empty to use SDK fallback for every read (no MCP credit). With
# MCP enabled, run_query uses splunk_run_query and the Translator uses the AI
# Assistant's saia_generate_spl tool. The run log records used_mcp=true so you
# can prove MCP actually served calls.
MCP_URL=
MCP_TOKEN=

# --- LLM endpoint (OpenAI-compatible chat completions) ------------------------
# Path A (Splunk-hosted Foundation-Sec): point at the Splunk-hosted endpoint.
# Path B (self-hosted via Ollama):
#   ollama serve
#   ollama pull foundation-sec:8b-instruct   (or similar)
#   LLM_BASE_URL=http://localhost:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=not-needed-for-local
LLM_MODEL=foundation-sec-8b-instruct

